# ─────────────────────────────────────────────────────────────────────────
#  Copiá este archivo a `.env` y completá los valores. `.env` NO se commitea.
# ─────────────────────────────────────────────────────────────────────────

# ── OAuth2 — API de datos (api.mercadolibre.com) ────────────────────────────
# Se usan SOLO del lado del servidor (SSR endpoints + scripts). Nunca en el cliente.
# El refresh_token se obtiene una vez con `npm run get-refresh-token`
# (flujo de autorización, scope `offline_access read`).
ML_CLIENT_ID=
ML_CLIENT_SECRET=
ML_REFRESH_TOKEN=

# (Opcional) Redirect URI registrada en tu app de ML. Solo la usa
# `get-refresh-token` para el intercambio del authorization code.
ML_REDIRECT_URI=https://localhost/callback

# ── Sesión de afiliados — SOLO para el job de minteo (scripts/mint-links) ────
# Estas son credenciales de SESIÓN del navegador, NO el token de OAuth2.
# Se copian desde DevTools (ver README → "Recapturar la sesión de afiliados").
# Vencen seguido: si el minteo devuelve 401/403, hay que recapturarlas.
ML_AFFILIATE_COOKIE=
ML_AFFILIATE_CSRF=
ML_AFFILIATE_TAG=matascrespi

# ── (Opcional) Generación de descripciones con la API de Anthropic ──────────
# Si está vacío, el job genera descripciones por plantilla (sin llamada externa).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
