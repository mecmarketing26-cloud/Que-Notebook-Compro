---
import type { NotebookProduct } from '../../lib/types';
import { specSummary } from '../../shared/attributes.mjs';
import { PRODUCTO } from '../../data/copy';

interface Props {
  product: NotebookProduct;
  lazy?: boolean;
  rank?: number; // 1-based position for podium ranking
  compare?: boolean; // show the "comparar" toggle
}
const { product: p, lazy = true, rank, compare = false } = Astro.props;

const fmt = (n: number) => new Intl.NumberFormat('es-AR', { style: 'currency', currency: p.currency || 'ARS', maximumFractionDigits: 0 }).format(n);
const formattedPrice = p.price != null ? fmt(p.price) : null;
const formattedOld = p.originalPrice ? fmt(p.originalPrice) : null;
const discount = p.discountPct && p.discountPct >= 5 ? p.discountPct : null;

const specs = specSummary(p.specs);

const MEDALS = ['🥇', '🥈', '🥉'];
const RIBBON = ['La mejor opción', '2ª mejor opción', '3ª mejor opción'];
const isPodium = rank != null && rank <= 3;
---

<article class={`card product-card${isPodium ? ` podium podium-${rank}` : ''}`}>
  {isPodium && (
    <div class={`podium-ribbon podium-ribbon-${rank}`}>
      <span class="podium-medal">{MEDALS[rank! - 1]}</span>{RIBBON[rank! - 1]}
    </div>
  )}

  <div class="card-media">
    {rank != null && rank > 3 && <span class="rank-num">#{rank}</span>}
    {compare && (
      <label class="compare-check" title="Marcar para comparar">
        <input type="checkbox" data-compare-id={p.id} data-compare-title={p.title} />
        <span class="cc-label">Comparar</span>
      </label>
    )}
    {discount && <span class="discount-badge">-{discount}%</span>}
    <a href={`/notebook/${p.id}`} class="card-image-link" aria-label={`Ver ${p.title}`}>
      <img src={p.image} alt={p.title} loading={lazy ? 'lazy' : 'eager'} decoding="async" width="400" height="400" class="card-img" />
    </a>
  </div>

  <div class="card-body">
    <h2 class="card-title"><a href={`/notebook/${p.id}`}>{p.title}</a></h2>

    {specs && <p class="card-specs">{specs}</p>}

    <div class="card-footer">
      <div class="price-area">
        {formattedPrice
          ? (
            <div class="price-stack">
              {formattedOld && (
                <span class="price-old-row">
                  <span class="price-old">{formattedOld}</span>
                  {discount && <span class="price-off">-{discount}%</span>}
                </span>
              )}
              <span class="price-now-row">
                <span class="price-from">{PRODUCTO.precio_desde}</span>
                <span class="price-tag">{formattedPrice}</span>
              </span>
            </div>
          )
          : (<span class="no-price">{PRODUCTO.sin_precio}</span>)
        }
      </div>
      <a
        href={p.shortUrl}
        class="btn btn-ml card-cta"
        target="_blank"
        rel="sponsored noopener noreferrer"
        data-item-id={p.id}
        data-item-price={p.price ?? ''}
      >
        {PRODUCTO.cta_comprar}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7M7 7h10v10"></path></svg>
      </a>
    </div>

    <div class="card-meta">
      <a href={`/notebook/${p.id}`} class="card-details-link">Ver ficha y opinión →</a>
      <span class="affiliate-chip" title="Enlace de afiliado de Mercado Libre">
        <svg width="10" height="10" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
          <path d="M6 0a6 6 0 1 0 0 12A6 6 0 0 0 6 0zm.75 9H5.25V5.25h1.5V9zm0-4.5H5.25V3h1.5v1.5z"/>
        </svg>
        Afiliado
      </span>
    </div>
  </div>
</article>

<script>
  import { trackAffiliateClick } from '../../lib/analytics';
  document.addEventListener('click', (e) => {
    const el = (e.target as HTMLElement)?.closest?.('[data-item-id]') as HTMLElement | null;
    if (!el) return;
    trackAffiliateClick(el.dataset.itemId ?? '', {
      price: el.dataset.itemPrice ? Number(el.dataset.itemPrice) : undefined,
    });
  });
</script>

<style>
  .product-card { display: flex; flex-direction: column; height: 100%; }
  .card-media { position: relative; }

  /* ── Podium ── */
  .podium-1 { box-shadow: 0 0 0 2px var(--color-amber), var(--shadow-card); }
  .podium-2 { box-shadow: 0 0 0 2px #c8c8d4, var(--shadow-card); }
  .podium-3 { box-shadow: 0 0 0 2px #d39256, var(--shadow-card); }
  .podium-ribbon {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    padding: 8px 10px; font-weight: 800; font-size: 0.82rem; letter-spacing: 0.02em;
    text-transform: uppercase; color: var(--color-navy);
  }
  .podium-medal { font-size: 1.05rem; }
  .podium-ribbon-1 { background: linear-gradient(90deg, #FFE259, #FFC233); }
  .podium-ribbon-2 { background: linear-gradient(90deg, #eef0f4, #c8ccd6); }
  .podium-ribbon-3 { background: linear-gradient(90deg, #f0c89a, #d39256); }
  .rank-num {
    position: absolute; top: 8px; left: 8px; z-index: 3;
    background: var(--color-navy); border: none;
    border-radius: var(--radius-pill); padding: 4px 11px; font-weight: 800; font-size: 0.82rem; color: #fff;
  }

  /* ── Discount badge: abajo-izquierda de la imagen (no pelea con el checkbox
     de Comparar arriba-der ni con el # de ranking arriba-izq). La card recorta
     con overflow:hidden, así que nunca desborda. ── */
  .discount-badge {
    position: absolute; bottom: 8px; left: 8px; z-index: 4;
    background: var(--color-green-soft);
    color: var(--color-green-text); font-weight: 800; font-size: 0.78rem;
    padding: 3px 8px; border-radius: 6px;
  }

  /* ── Compare toggle: mismo lugar en todas las cards, sin desbordar el ancho ── */
  .compare-check {
    position: absolute; top: 8px; right: 8px; z-index: 5;
    display: inline-flex; align-items: center; gap: 5px;
    max-width: calc(100% - 16px); white-space: nowrap;
    background: rgba(255,255,255,0.95); border: 1.5px solid var(--color-card-border);
    border-radius: var(--radius-pill); padding: 5px 9px; cursor: pointer;
    font-size: 0.72rem; font-weight: 700; color: var(--color-text-soft); user-select: none;
    box-shadow: 0 1px 6px rgba(30,27,22,0.10);
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }
  .compare-check:hover { border-color: var(--color-blue); color: var(--color-navy); }
  .compare-check input { width: 15px; height: 15px; accent-color: var(--color-blue); cursor: pointer; margin: 0; }
  .compare-check:has(input:checked) { background: var(--color-blue); border-color: var(--color-blue); color: #fff; }

  .card-specs {
    font-size: 0.78rem; color: var(--color-text-soft); font-weight: 600; line-height: 1.4;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }

  /* ── Price ── */
  .price-stack { display: flex; flex-direction: column; gap: 1px; }
  .price-old-row { display: flex; align-items: center; gap: 8px; }
  .price-old { color: var(--color-text-muted); font-size: 0.8rem; text-decoration: line-through; }
  .price-off { color: var(--color-green-text); font-size: 0.72rem; font-weight: 800; }
  .price-now-row { display: flex; align-items: baseline; gap: 4px; }
  .price-from { color: var(--color-text-secondary); font-size: 0.75rem; margin-right: 2px; }

  /* ── Fila meta: acceso a la ficha + disclosure mínima ── */
  .card-meta { display: flex; align-items: center; justify-content: space-between; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
  .card-details-link { font-size: 0.78rem; font-weight: 700; color: var(--color-blue); }
  .card-details-link:hover { text-decoration: underline; }
  .card-meta .affiliate-chip { display: inline-flex; align-items: center; gap: 4px; font-size: 0.68rem; color: var(--color-text-muted); }
</style>
