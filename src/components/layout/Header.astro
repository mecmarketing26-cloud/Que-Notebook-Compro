---
import { SITE } from '../../data/copy';
---

<header class="site-header">
  <nav class="nav-inner" aria-label="Navegación principal">
    <a href="/" class="nav-logo" aria-label={SITE.name}>
      <span class="logo-mark" aria-hidden="true">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#FFC233" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="4" rx="2"></rect><path d="M2 20h20"></path></svg>
      </span>
      <span class="logo-word">¿Qué Notebook?</span>
    </a>

    <div class="nav-actions">
      <a href="/" class="nav-link">Inicio</a>
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/quiz" class="nav-cta ctaQuiz">
        Hacer el test
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#16224C" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
      </a>
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 0 var(--space-lg);
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-card-border);
  }

  .nav-inner {
    max-width: 460px;
    margin: 0 auto;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--color-navy);
  }
  .logo-word {
    font-family: 'Bricolage Grotesque', sans-serif;
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: -0.03em;
    color: var(--color-navy);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .nav-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-soft);
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--color-navy); }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    height: 34px;
    padding: 0 14px;
    border-radius: 10px;
    background: var(--color-amber);
    color: var(--color-navy);
    font-family: 'Hanken Grotesk', sans-serif;
    font-weight: 800;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .site-header { padding: 0 var(--space-md); }
    .logo-word   { font-size: 0.95rem; }
    .nav-link    { display: none; }
    .nav-actions { gap: var(--space-sm); }
    .nav-cta     { font-size: 0.78rem; padding: 0 12px; }
  }
</style>
