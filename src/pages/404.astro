---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { NOT_FOUND, SITE } from '../data/copy';
---

<BaseLayout
  title={`404 — ${SITE.name}`}
  description="Esta página no existe."
  noindex
>
  <Header />

  <main class="not-found-page">
    <div class="not-found-content">
      <p class="not-found-emoji" aria-hidden="true">💻</p>
      <h1 class="not-found-title">{NOT_FOUND.titulo}</h1>
      <p class="not-found-msg">{NOT_FOUND.mensaje}</p>
      <a href="/" class="btn btn-primary">{NOT_FOUND.cta}</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .not-found-page {
    min-height: 100dvh;
    padding-top: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px var(--space-lg) var(--space-3xl);
  }

  .not-found-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    max-width: 480px;
    animation: fade-up 0.4s ease;
  }

  .not-found-emoji { font-size: 5rem; }

  .not-found-title {
    font-family: 'Bricolage Grotesque Variable', sans-serif;
    font-weight: 800;
    letter-spacing: -0.03em;
    font-size: clamp(2.2rem, 7vw, 3.6rem);
    color: var(--color-navy);
    line-height: 1.05;
  }

  .not-found-msg {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
  }
</style>
