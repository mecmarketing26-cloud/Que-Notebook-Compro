---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE, FAQ, CTA_QUIZ } from '../data/copy';
import { catalogStatus } from '../lib/catalog';
import { getFeatured } from '../lib/live-search';
import { specSummary } from '../shared/attributes.mjs';
import { quickPickFilters, filtersToQuery } from '../shared/quiz-map.mjs';
import { getTopic, categoryFor } from '../data/blog';
import { allProducts } from '../lib/catalog-data';
import { recommend } from '../shared/filter-engine.mjs';
import { mlThumb, ML_IMG_ONERROR } from '../lib/ml-image';

const status = catalogStatus();
let featured = await getFeatured(8).catch(() => []);

const fmt = (n: number) =>
  new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', maximumFractionDigits: 0 }).format(n);

const top = featured[0];
const vsA = featured[1];
const vsB = featured[2];

// Hero "palabra gigante": los 4 equipos son PNGs transparentes recortados de
// fotos reales del catálogo (regenerables con `node scripts/hero-cutouts.mjs`).
// Mismo orden que WORDS en el script: notebook → MacBook → Chromebook → laptop.
const HERO_DEVICES = ['/img/hero/notebook.webp', '/img/hero/macbook.webp', '/img/hero/chromebook.webp', '/img/hero/laptop.webp'];

// "Por uso" — 6 íconos de línea que deep-linkean a resultados ya filtrados.
const USOS: Array<{ key: string; label: string; svg: string }> = [
  { key: 'gaming', label: 'Gaming', svg: '<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258"/>' },
  { key: 'estudio', label: 'Estudio', svg: '<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>' },
  { key: 'diseno', label: 'Diseño', svg: '<circle cx="13.5" cy="6.5" r=".7" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".7" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".7" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".7" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>' },
  { key: 'programacion', label: 'Programar', svg: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' },
  { key: 'basico', label: 'Uso básico', svg: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20M2 12h20"/>' },
  { key: 'premium', label: 'Alta gama', svg: '<path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6M2 9h20"/>' },
];
const usos = USOS.map((u) => ({ ...u, href: `/resultado?${filtersToQuery(quickPickFilters(u.key))}` }));

// Arranca en la 1ª pregunta (elegir modo). Antes iba a /quiz?modo=guiado, que
// salteaba esa pregunta y hacía "empezar" en el paso 2.
const quizHref = '/quiz';

// Guías del blog en la home ("Aprendé antes de comprar"): 3 temas REALES del blog
// (para no linkear a 404). Portada = imagen del equipo #1 de cada ranking, en build.
function coverFor(topic: any): string | null {
  let pool = allProducts();
  if (topic?.match) pool = pool.filter(topic.match);
  const { products } = recommend(pool, topic?.filters ?? {}, { min: 1, max: 1 });
  return products[0]?.image ?? null;
}
const GUIDE_SLUGS = ['mejores-notebooks-16gb-ram', 'mejores-notebooks-i7', 'mejores-notebooks-para-estudiar'];
const guides = GUIDE_SLUGS.map((slug) => {
  const t = getTopic(slug);
  return { slug, title: t?.h1 ?? slug, category: categoryFor(slug), cover: t ? coverFor(t) : null };
});

// Chips de búsqueda rápida (deep-link a /resultado?q=...).
const SEARCH_CHIPS = ['Lenovo', 'ASUS', 'Acer', 'HP', 'RTX 4060', 'Ryzen 7'];

// JSON-LD de la home: Organization (branding en resultados) + WebSite con
// SearchAction (la búsqueda real del sitio: /resultado?q=) + FAQPage (rich snippet).
const siteUrl = Astro.site!.toString();
const faqJsonLd = JSON.stringify([
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: SITE.name,
    url: siteUrl,
    logo: new URL('/apple-touch-icon.png', Astro.site).toString(),
    description: SITE.description,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: siteUrl,
    inLanguage: 'es-AR',
    potentialAction: {
      '@type': 'SearchAction',
      target: { '@type': 'EntryPoint', urlTemplate: `${siteUrl}resultado?q={search_term_string}` },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: FAQ.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
  },
]);

function gpuLabel(p: any): string {
  const s = p?.specs ?? {};
  if (s.gpuModel) return s.gpuModel;
  if (s.gpuDedicated === true) return 'Dedicada';
  if (s.gpuDedicated === false) return 'Integrada';
  return '—';
}
function screenLabel(p: any): string {
  const s = p?.specs ?? {};
  if (s.screenInches && s.refreshHz) return `${s.refreshHz}Hz`;
  if (s.screenInches) return `${s.screenInches}"`;
  return '—';
}
---

<BaseLayout title={`${SITE.name} — Recomendador de notebooks`} jsonLd={faqJsonLd}>
  <Header />

  <main class="home">
    <div class="bento">

      <!-- HERO 3c "Palabra gigante": la palabra rotativa es la protagonista.
           Centrado, sin ícono flotante ni flecha de scroll; termina donde
           termina el contenido. -->
      <section class="b-hero">
        <h1 class="b-hero-title">
          <span class="b-hero-small">¿Qué</span>
          <span class="b-hero-word" id="heroWord">notebook</span>
          <span class="b-hero-small">compro?</span>
        </h1>
        <p class="b-hero-sub">Contestá 5 preguntas y te decimos cuál es para vos.</p>
        <!-- Escenario con profundidad: los 4 equipos SIEMPRE visibles; el de la
             palabra activa pasa al frente, el resto queda detrás, chico y
             difuminado. Glow central para despegarlos del navy. -->
        <div class="b-hero-stage" aria-hidden="true">
          <span class="b-hero-glow"></span>
          {HERO_DEVICES.map((src, i) => (
            <img
              class="b-hero-dev"
              data-idx={i}
              data-pos={i}
              src={src}
              alt=""
              width="320"
              height="230"
              fetchpriority={i === 0 ? 'high' : undefined}
              decoding="async"
            />
          ))}
        </div>
        <a href={quizHref} class="b-hero-btn ctaQuiz">
          {CTA_QUIZ.label}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#1E2A5A" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
        </a>
        <p class="b-hero-trust">✓ Gratis · Sin registro · Menos de 2 min</p>
      </section>

      <!-- BUSCADOR -->
      <section class="b-search" id="contenido">
        <form class="search-form" action="/resultado" method="get" role="search">
          <span class="search-ico" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </span>
          <input class="search-input" type="search" name="q" autocomplete="off" enterkeyhint="search"
            placeholder="Buscá una notebook, marca o componente (ej.: Lenovo Legion, RTX 4060, Ryzen 7…)"
            aria-label="Buscar notebooks, marcas o componentes" />
          <button class="search-btn" type="submit" aria-label="Buscar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16224C" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </button>
        </form>
        <div class="search-chips">
          {SEARCH_CHIPS.map((c) => (
            <a class="search-chip" href={`/resultado?q=${encodeURIComponent(c)}`}>{c}</a>
          ))}
        </div>
      </section>

      <!-- POR USO -->
      <section class="b-card b-uso lift">
        <h2 class="b-card-h">Por uso</h2>
        <div class="uso-grid">
          {usos.map((u) => (
            <a href={u.href} class="ico-tile icoTile">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={u.svg}></svg>
              <span>{u.label}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- TOP DEL DÍA -->
      <section class="b-card b-top lift" data-list="home_top">
        <div class="b-top-head">
          <h2 class="b-card-h">Top del día</h2>
          {top?.discountPct && top.discountPct >= 5 && <span class="badge-disc">-{top.discountPct}%</span>}
        </div>
        <a href={top ? `/notebook/${top.id}` : quizHref} class="b-top-img">
          {top?.image
            ? <img src={mlThumb(top.image)} onerror={ML_IMG_ONERROR} alt={top.title} loading="lazy" decoding="async" />
            : <span class="ph" aria-hidden="true"></span>}
        </a>
        <div class="b-top-title">{top ? top.title : 'Tu próxima notebook'}</div>
        <div class="b-top-price">{top?.price != null ? fmt(top.price) : '—'}</div>
        <div class="b-top-note">{top ? 'Precio verificado en vivo' : 'Hacé el test y te la mostramos'}</div>
      </section>

      <!-- COMPARADOR (feature destacado: pasos visuales, ejemplo y CTA) -->
      <section class="b-cmp lift">
        <span class="b-cmp-eyebrow">Herramienta gratis</span>
        <h2 class="b-cmp-h">Compará 2 notebooks frente a frente</h2>
        <ol class="b-cmp-steps">
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11l3 3L22 4"></path><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
            <span>Elegí 2 modelos</span>
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="7" height="16" rx="1.5"></rect><rect x="14" y="4" width="7" height="16" rx="1.5"></rect></svg>
            <span>Miralas juntas</span>
          </li>
          <li>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
            <span>Decidí fácil</span>
          </li>
        </ol>
        <div class="b-cmp-row" data-list="home_comparador">
          <div class="b-cmp-card">
            <a href={vsA ? `/notebook/${vsA.id}` : quizHref} class="b-cmp-img">
              {vsA?.image ? <img src={mlThumb(vsA.image)} onerror={ML_IMG_ONERROR} alt={vsA.title} loading="lazy" /> : <span class="ph" aria-hidden="true"></span>}
            </a>
            <div class="b-cmp-title">{vsA ? vsA.title : 'Opción A'}</div>
            <div class="b-cmp-price">{vsA?.price != null ? fmt(vsA.price) : '—'}</div>
            <div class="b-cmp-spec"><span>GPU</span><b>{gpuLabel(vsA)}</b></div>
            <div class="b-cmp-spec"><span>Pantalla</span><b>{screenLabel(vsA)}</b></div>
          </div>
          <span class="vs-chip">VS</span>
          <div class="b-cmp-card">
            <a href={vsB ? `/notebook/${vsB.id}` : quizHref} class="b-cmp-img">
              {vsB?.image ? <img src={mlThumb(vsB.image)} onerror={ML_IMG_ONERROR} alt={vsB.title} loading="lazy" /> : <span class="ph" aria-hidden="true"></span>}
            </a>
            <div class="b-cmp-title">{vsB ? vsB.title : 'Opción B'}</div>
            <div class="b-cmp-price">{vsB?.price != null ? fmt(vsB.price) : '—'}</div>
            <div class="b-cmp-spec"><span>GPU</span><b>{gpuLabel(vsB)}</b></div>
            <div class="b-cmp-spec"><span>Pantalla</span><b>{screenLabel(vsB)}</b></div>
          </div>
        </div>
        <a href="/comparar" class="b-cmp-btn">
          Probar el comparador
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16224C" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
        </a>
      </section>

      <!-- GUÍAS DEL BLOG (SEO) -->
      <section class="b-guides">
        <div class="b-guides-head">
          <h2 class="b-card-h">Guías para elegir mejor</h2>
          <a href="/blog" class="b-guides-link">Ver todas las guías →</a>
        </div>
        <div class="guides-grid">
          {guides.map((g) => (
            <BlogCard slug={g.slug} title={g.title} category={g.category} cover={g.cover} cta="Ver ranking →" />
          ))}
        </div>
      </section>

      <!-- STAT -->
      <section class="b-stat lift">
        <span class="b-stat-num">Todas</span>
        <span class="b-stat-txt">las notebooks <b>disponibles</b> de Mercado Libre, con precio actualizado</span>
      </section>

      <!-- PREGUNTAS FRECUENTES (acordeón + JSON-LD FAQPage) -->
      <section class="b-faq">
        <h2 class="b-card-h b-faq-h">Preguntas frecuentes</h2>
        <div class="faq-list">
          {FAQ.map((f) => (
            <details class="faq-item">
              <summary class="faq-q">
                <span>{f.q}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
              </summary>
              <div class="faq-a">{f.a}</div>
            </details>
          ))}
        </div>
      </section>

      {!status.ready && (
        <p class="b-note">El catálogo se está cargando. Corré <code>npm run catalog:backfill</code> (o <code>catalog:grow</code>) para poblarlo y volvé a buildear.</p>
      )}

    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Hero "palabra gigante": la palabra rota y el equipo de esa palabra pasa al
  // frente del escenario (los 4 están siempre visibles, en profundidad). El JS
  // solo actualiza data-pos; el movimiento lo hace la transición CSS.
  const wordEl = document.getElementById('heroWord');
  const devices = Array.from(document.querySelectorAll<HTMLElement>('.b-hero-dev'));
  const WORDS = ['notebook', 'MacBook', 'Chromebook', 'laptop'];
  if (wordEl && devices.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let active = 0;
    setInterval(() => {
      active = (active + 1) % WORDS.length;
      wordEl.textContent = WORDS[active];
      wordEl.classList.remove('in');
      void (wordEl as HTMLElement).offsetWidth; // reinicia la animación
      wordEl.classList.add('in');
      for (const dev of devices) {
        dev.dataset.pos = String((Number(dev.dataset.idx) - active + WORDS.length) % WORDS.length);
      }
    }, 2200);
  }
</script>

<style>
  .home { padding-top: 64px; background: var(--color-bg-deep); }
  .bento {
    max-width: 460px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md) var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    align-items: start;
  }

  .b-card-h { font-family: 'Bricolage Grotesque Variable', sans-serif; font-weight: 700; font-size: 0.95rem; color: var(--color-navy); }

  /* ── HERO 3c "Palabra gigante" ──
     Jerarquía invertida: "¿Qué … compro?" chico y apagado; la palabra rotativa
     es la protagonista (gigante, ámbar, centrada). min-height en la palabra
     reserva su línea: el swap nunca deja hueco ni salta el layout. */
  .b-hero {
    grid-column: 1 / -1;
    /* Primera pantalla completa: ninguna otra sección se asoma hasta scrollear
       (100dvh menos header fijo y padding superior del bento). */
    min-height: calc(100dvh - 64px - var(--space-lg));
    display: flex; flex-direction: column; justify-content: center;
    background: #1E2A5A; color: #fff;
    border-radius: var(--radius-lg); padding: 32px 22px 26px;
    text-align: center;
  }
  .b-hero-title { display: flex; flex-direction: column; font-family: 'Bricolage Grotesque Variable', sans-serif; font-weight: 800; }
  .b-hero-small { font-size: 24px; color: #C6CCDF; line-height: 1.1; }
  .b-hero-word {
    font-size: clamp(40px, 12.5vw, 52px); color: var(--color-amber);
    line-height: 1.05; letter-spacing: -0.03em; min-height: 56px; margin: 2px 0;
  }
  .b-hero-word.in { animation: wordIn 0.45s cubic-bezier(0.2, 0.7, 0.3, 1); }
  @keyframes wordIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .b-hero-sub { font-size: 15px; line-height: 1.5; color: #C6CCDF; max-width: 280px; margin: 18px auto 0; }

  /* Escenario de equipos: PNGs transparentes apilados con profundidad.
     data-pos: 0 = frente · 1 = atrás-derecha · 2 = fondo · 3 = atrás-izquierda.
     El JS solo cambia data-pos; el resto lo hace la transición CSS. */
  .b-hero-stage { position: relative; width: 100%; max-width: 330px; height: 195px; margin: 22px auto 0; }
  .b-hero-glow {
    position: absolute; left: 50%; top: 54%; transform: translate(-50%, -50%);
    width: 270px; height: 175px; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(255,194,51,0.34), rgba(255,194,51,0.10) 55%, transparent 78%);
    filter: blur(8px);
  }
  .b-hero-dev {
    position: absolute; left: 50%; top: 50%;
    width: auto; height: auto; max-width: 295px; max-height: 185px;
    transition: transform 0.55s cubic-bezier(0.2, 0.7, 0.3, 1), opacity 0.55s ease, filter 0.55s ease;
    will-change: transform, opacity;
  }
  .b-hero-dev[data-pos="0"] { transform: translate(-50%, -50%) scale(1); opacity: 1; z-index: 3; filter: drop-shadow(0 20px 26px rgba(0, 0, 0, 0.5)); }
  .b-hero-dev[data-pos="1"] { transform: translate(calc(-50% + 82px), -56%) scale(0.6); opacity: 0.35; z-index: 2; filter: blur(1.5px); }
  .b-hero-dev[data-pos="2"] { transform: translate(-50%, -66%) scale(0.48); opacity: 0.16; z-index: 1; filter: blur(2.5px); }
  .b-hero-dev[data-pos="3"] { transform: translate(calc(-50% - 82px), -56%) scale(0.6); opacity: 0.35; z-index: 2; filter: blur(1.5px); }
  .b-hero-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    width: 100%; height: 52px; margin-top: 20px; border-radius: 13px;
    background: var(--color-amber); color: #1E2A5A;
    font-family: 'Hanken Grotesk Variable', sans-serif; font-weight: 800; font-size: 15px;
  }
  .b-hero-trust { font-size: 12px; font-weight: 600; color: #AAB2CF; margin-top: 12px; }
  @media (prefers-reduced-motion: reduce) {
    .b-hero-word.in { animation: none; }
  }

  /* ── POR USO ── */
  .b-card { background: var(--color-card); border: 1px solid var(--color-card-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); padding: 16px; display: flex; flex-direction: column; }
  .b-uso .uso-grid { margin-top: 12px; flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .ico-tile {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
    border-radius: 12px; background: var(--color-tile); border: 1px solid var(--color-card-border);
    padding: 12px 4px; color: var(--color-blue);
  }
  .ico-tile span { font-size: 0.7rem; font-weight: 600; color: var(--color-text-primary); }

  /* ── TOP DEL DÍA ── */
  .b-top-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .badge-disc { font-size: 0.65rem; font-weight: 800; color: var(--color-green-text); background: var(--color-green-soft); padding: 2px 7px; border-radius: 5px; }
  .b-top-img { display: block; aspect-ratio: 4/3; border-radius: 9px; background: #faf9f5; overflow: hidden; margin-bottom: 10px; }
  .b-top-img img { width: 100%; height: 100%; object-fit: contain; padding: 10px; }
  .b-top-title { font-size: 0.8rem; font-weight: 600; line-height: 1.25; color: var(--color-text-primary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
