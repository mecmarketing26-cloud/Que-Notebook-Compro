---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE, FAQ } from '../data/copy';
import { catalogStatus } from '../lib/catalog';
import { getFeatured } from '../lib/live-search';
import { specSummary } from '../shared/attributes.mjs';
import { quickPickFilters, filtersToQuery } from '../shared/quiz-map.mjs';
import { getTopic, categoryFor } from '../data/blog';
import { allProducts } from '../lib/catalog-data';
import { recommend } from '../shared/filter-engine.mjs';

const status = catalogStatus();
let featured = await getFeatured(8).catch(() => []);

const fmt = (n: number) =>
  new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', maximumFractionDigits: 0 }).format(n);

const top = featured[0];
const vsA = featured[1];
const vsB = featured[2];

// "Por uso" — 6 íconos de línea que deep-linkean a resultados ya filtrados.
const USOS: Array<{ key: string; label: string; svg: string }> = [
  { key: 'gaming', label: 'Gaming', svg: '<line x1="6" x2="10" y1="11" y2="11"/><line x1="8" x2="8" y1="9" y2="13"/><line x1="15" x2="15.01" y1="12" y2="12"/><line x1="18" x2="18.01" y1="10" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258"/>' },
  { key: 'estudio', label: 'Estudio', svg: '<path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/>' },
  { key: 'diseno', label: 'Diseño', svg: '<circle cx="13.5" cy="6.5" r=".7" fill="currentColor"/><circle cx="17.5" cy="10.5" r=".7" fill="currentColor"/><circle cx="8.5" cy="7.5" r=".7" fill="currentColor"/><circle cx="6.5" cy="12.5" r=".7" fill="currentColor"/><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.926 0 1.648-.746 1.648-1.688 0-.437-.18-.835-.437-1.125-.29-.289-.438-.652-.438-1.125a1.64 1.64 0 0 1 1.668-1.668h1.996c3.051 0 5.555-2.503 5.555-5.554C21.965 6.012 17.461 2 12 2z"/>' },
  { key: 'programacion', label: 'Programar', svg: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>' },
  { key: 'basico', label: 'Uso básico', svg: '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20M2 12h20"/>' },
  { key: 'premium', label: 'Alta gama', svg: '<path d="M6 3h12l4 6-10 13L2 9Z"/><path d="M11 3 8 9l4 13 4-13-3-6M2 9h20"/>' },
];
const usos = USOS.map((u) => ({ ...u, href: `/resultado?${filtersToQuery(quickPickFilters(u.key))}` }));

// Arranca en la 1ª pregunta (elegir modo). Antes iba a /quiz?modo=guiado, que
// salteaba esa pregunta y hacía "empezar" en el paso 2.
const quizHref = '/quiz';

// Guías del blog en la home ("Aprendé antes de comprar"): 3 temas REALES del blog
// (para no linkear a 404). Portada = imagen del equipo #1 de cada ranking, en build.
function coverFor(topic: any): string | null {
  let pool = allProducts();
  if (topic?.match) pool = pool.filter(topic.match);
  const { products } = recommend(pool, topic?.filters ?? {}, { min: 1, max: 1 });
  return products[0]?.image ?? null;
}
const GUIDE_SLUGS = ['mejores-notebooks-16gb-ram', 'mejores-notebooks-i7', 'mejores-notebooks-para-estudiar'];
const guides = GUIDE_SLUGS.map((slug) => {
  const t = getTopic(slug);
  return { slug, title: t?.h1 ?? slug, category: categoryFor(slug), cover: t ? coverFor(t) : null };
});

// Palabra animada del hero (rota suave; la 1ª se pinta en el server).
const HERO_WORDS = ['notebook', 'laptop', 'MacBook', 'Chromebook', 'ultrabook'];
// Chips de búsqueda rápida (deep-link a /resultado?q=...).
const SEARCH_CHIPS = ['Lenovo', 'ASUS', 'Acer', 'HP', 'RTX 4060', 'Ryzen 7'];

// FAQ → JSON-LD FAQPage (rich snippet en Google).
const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
});

function gpuLabel(p: any): string {
  const s = p?.specs ?? {};
  if (s.gpuModel) return s.gpuModel;
  if (s.gpuDedicated === true) return 'Dedicada';
  if (s.gpuDedicated === false) return 'Integrada';
  return '—';
}
function screenLabel(p: any): string {
  const s = p?.specs ?? {};
  if (s.screenInches && s.refreshHz) return `${s.refreshHz}Hz`;
  if (s.screenInches) return `${s.screenInches}"`;
  return '—';
}
---

<BaseLayout title={`${SITE.name} — Recomendador de notebooks`} jsonLd={faqJsonLd}>
  <Header />

  <main class="home">
    <div class="bento">

      <!-- HERO -->
      <section class="b-hero lift">
        <span class="b-hero-blob" aria-hidden="true">
          <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#FFC233" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="5" width="16" height="11" rx="1.5"></rect>
            <path d="M2 19h20"></path>
            <path d="M9.4 19l.4-1.6h4.4l.4 1.6"></path>
          </svg>
        </span>
        <h1 class="b-hero-title">Encontrá la <span class="rotator" data-words={HERO_WORDS.join(',')}><span class="rotator-sizer" aria-hidden="true">Chromebook</span><span class="rotator-word" id="heroWord">{HERO_WORDS[0]}</span></span> que realmente te conviene</h1>
        <a href={quizHref} class="b-hero-btn ctaQuiz">
          Encontrar mi equipo
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#16224C" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
        </a>
        <p class="b-hero-microcopy">Gratis · Sin registro · Menos de 2 minutos</p>
      </section>

      <!-- BUSCADOR -->
      <section class="b-search">
        <form class="search-form" action="/resultado" method="get" role="search">
          <span class="search-ico" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="m21 21-4.3-4.3"></path></svg>
          </span>
          <input class="search-input" type="search" name="q" autocomplete="off" enterkeyhint="search"
            placeholder="Buscá una notebook, marca o componente (ej.: Lenovo Legion, RTX 4060, Ryzen 7…)"
            aria-label="Buscar notebooks, marcas o componentes" />
          <button class="search-btn" type="submit" aria-label="Buscar">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16224C" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
          </button>
        </form>
        <div class="search-chips">
          {SEARCH_CHIPS.map((c) => (
            <a class="search-chip" href={`/resultado?q=${encodeURIComponent(c)}`}>{c}</a>
          ))}
        </div>
      </section>

      <!-- POR USO -->
      <section class="b-card b-uso lift">
        <h2 class="b-card-h">Por uso</h2>
        <div class="uso-grid">
          {usos.map((u) => (
            <a href={u.href} class="ico-tile icoTile">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={u.svg}></svg>
              <span>{u.label}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- TOP DEL DÍA -->
      <section class="b-card b-top lift">
        <div class="b-top-head">
          <h2 class="b-card-h">Top del día</h2>
          {top?.discountPct && top.discountPct >= 5 && <span class="badge-disc">-{top.discountPct}%</span>}
        </div>
        <a href={top ? `/notebook/${top.id}` : quizHref} class="b-top-img">
          {top?.image
            ? <img src={top.image} alt={top.title} loading="lazy" decoding="async" />
            : <span class="ph" aria-hidden="true"></span>}
        </a>
        <div class="b-top-title">{top ? top.title : 'Tu próxima notebook'}</div>
        <div class="b-top-price">{top?.price != null ? fmt(top.price) : '—'}</div>
        <div class="b-top-note">{top ? 'Precio verificado en vivo' : 'Hacé el test y te la mostramos'}</div>
      </section>

      <!-- COMPARAR LADO A LADO -->
      <section class="b-card b-cmp lift">
        <div class="b-cmp-head">
          <h2 class="b-card-h">Comparar lado a lado</h2>
          <a href="/comparar" class="b-cmp-link">Elegir 2 →</a>
        </div>
        <div class="b-cmp-row">
          <div class="b-cmp-card">
            <a href={vsA ? `/notebook/${vsA.id}` : quizHref} class="b-cmp-img">
              {vsA?.image ? <img src={vsA.image} alt={vsA.title} loading="lazy" /> : <span class="ph" aria-hidden="true"></span>}
            </a>
            <div class="b-cmp-title">{vsA ? vsA.title : 'Opción A'}</div>
            <div class="b-cmp-price">{vsA?.price != null ? fmt(vsA.price) : '—'}</div>
            <div class="b-cmp-spec"><span>GPU</span><b>{gpuLabel(vsA)}</b></div>
            <div class="b-cmp-spec"><span>Pantalla</span><b>{screenLabel(vsA)}</b></div>
          </div>
          <span class="vs-chip">VS</span>
          <div class="b-cmp-card">
            <a href={vsB ? `/notebook/${vsB.id}` : quizHref} class="b-cmp-img">
              {vsB?.image ? <img src={vsB.image} alt={vsB.title} loading="lazy" /> : <span class="ph" aria-hidden="true"></span>}
            </a>
            <div class="b-cmp-title">{vsB ? vsB.title : 'Opción B'}</div>
            <div class="b-cmp-price">{vsB?.price != null ? fmt(vsB.price) : '—'}</div>
            <div class="b-cmp-spec"><span>GPU</span><b>{gpuLabel(vsB)}</b></div>
            <div class="b-cmp-spec"><span>Pantalla</span><b>{screenLabel(vsB)}</b></div>
          </div>
        </div>
      </section>

      <!-- GUÍAS DEL BLOG (SEO) -->
      <section class="b-guides">
        <div class="b-guides-head">
          <h2 class="b-card-h">Aprendé antes de comprar</h2>
          <a href="/blog" class="b-guides-link">Ver todas las guías →</a>
        </div>
        <div class="guides-grid">
          {guides.map((g) => (
            <BlogCard slug={g.slug} title={g.title} category={g.category} cover={g.cover} cta="Ver ranking →" />
          ))}
        </div>
      </section>

      <!-- STAT -->
      <section class="b-stat lift">
        <span class="b-stat-num">Todas</span>
        <span class="b-stat-txt">las notebooks <b>disponibles</b> de Mercado Libre, con precio actualizado</span>
      </section>

      <!-- PREGUNTAS FRECUENTES (acordeón + JSON-LD FAQPage) -->
      <section class="b-faq">
        <h2 class="b-card-h b-faq-h">Preguntas frecuentes</h2>
        <div class="faq-list">
          {FAQ.map((f) => (
            <details class="faq-item">
              <summary class="faq-q">
                <span>{f.q}</span>
                <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg>
              </summary>
              <div class="faq-a">{f.a}</div>
            </details>
          ))}
        </div>
      </section>

      {!status.ready && (
        <p class="b-note">El catálogo se está cargando. Corré <code>npm run catalog:backfill</code> (o <code>catalog:grow</code>) para poblarlo y volvé a buildear.</p>
      )}

    </div>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  // Palabra animada del hero: rota suave en loop. Respeta prefers-reduced-motion
  // (si está activo, queda la palabra fija sin animación).
  (function () {
    var el = document.getElementById('heroWord');
    if (!el) return;
    var box = el.closest('.rotator');
    var words = ((box && box.getAttribute('data-words')) || '').split(',').filter(Boolean);
    if (words.length < 2) return;
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    var i = 0;
    setInterval(function () {
      el.classList.add('is-out');
      setTimeout(function () {
        i = (i + 1) % words.length;
        el.textContent = words[i];
        el.classList.remove('is-out');
      }, 380);
    }, 2200);
  })();
</script>

<style>
  .home { padding-top: 64px; background: var(--color-bg-deep); }
  .bento {
    max-width: 460px;
    margin: 0 auto;
    padding: var(--space-lg) var(--space-md) var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    align-items: start;
  }

  .b-card-h { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 0.95rem; color: var(--color-navy); }

  /* ── HERO ── */
  .b-hero {
    grid-column: 1 / -1; position: relative; overflow: hidden;
    background: var(--color-navy); color: #fff;
    border-radius: var(--radius-lg); padding: 24px 20px;
  }
  /* Círculo del hero: ya no vacío — lleva una ilustración de notebook (ámbar),
     detrás del texto (el texto/CTA van con z-index:1). */
  .b-hero-blob { position: absolute; right: -14px; top: -14px; width: 130px; height: 130px; border-radius: 50%; background: rgba(255,194,51,0.13); display: flex; align-items: center; justify-content: center; z-index: 0; }
  .b-hero-blob svg { transform: translate(-10px, 12px); opacity: 0.9; }
  .b-hero-eyebrow, .b-hero-title, .b-hero-btn, .b-hero-microcopy { position: relative; z-index: 1; }
  .b-hero-microcopy { margin-top: 11px; font-size: 0.74rem; font-weight: 500; color: rgba(255,255,255,0.6); }

  /* Palabra animada del hero (ámbar). El "sizer" reserva el ancho de la más larga
     para que el título no salte al rotar. */
  .rotator { position: relative; display: inline-block; }
  .rotator-sizer { visibility: hidden; }
  .rotator-word { position: absolute; left: 0; top: 0; color: var(--color-amber); white-space: nowrap; transition: opacity 0.38s ease, transform 0.38s ease; }
  .rotator-word.is-out { opacity: 0; transform: translateY(-0.28em); }
  @media (prefers-reduced-motion: reduce) { .rotator-word { transition: none; } }
  .b-hero-eyebrow { position: relative; display: block; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-amber); }
  .b-hero-title { position: relative; font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 1.85rem; line-height: 1.0; letter-spacing: -0.02em; margin: 10px 0 16px; }
  .b-hero-btn {
    position: relative; display: inline-flex; align-items: center; gap: 8px;
    height: 46px; padding: 0 20px; border-radius: 12px;
    background: var(--color-amber); color: var(--color-navy);
    font-family: 'Hanken Grotesk', sans-serif; font-weight: 800; font-size: 0.95rem;
  }

  /* ── POR USO ── */
  .b-card { background: var(--color-card); border: 1px solid var(--color-card-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); padding: 16px; display: flex; flex-direction: column; }
  .b-uso .uso-grid { margin-top: 12px; flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .ico-tile {
    display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px;
    border-radius: 12px; background: var(--color-tile); border: 1px solid var(--color-card-border);
    padding: 12px 4px; color: var(--color-blue);
  }
  .ico-tile span { font-size: 0.7rem; font-weight: 600; color: var(--color-text-primary); }

  /* ── TOP DEL DÍA ── */
  .b-top-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px; }
  .badge-disc { font-size: 0.65rem; font-weight: 800; color: var(--color-green-text); background: var(--color-green-soft); padding: 2px 7px; border-radius: 5px; }
  .b-top-img { display: block; aspect-ratio: 4/3; border-radius: 9px; background: #faf9f5; overflow: hidden; margin-bottom: 10px; }
  .b-top-img img { width: 100%; height: 100%; object-fit: contain; padding: 10px; }
  .b-top-title { font-size: 0.8rem; font-weight: 600; line-height: 1.25; color: var(--color-text-primary); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .b-top-price { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 1.15rem; color: var(--color-navy); margin-top: 3px; }
  .b-top-note { font-size: 0.66rem; color: var(--color-text-soft); margin-top: 2px; }

  /* ── COMPARAR ── */
  .b-cmp { grid-column: 1 / -1; }
  .b-cmp-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
  .b-cmp-link { font-size: 0.72rem; color: var(--color-blue); font-weight: 700; }
  .b-cmp-row { display: flex; align-items: stretch; gap: 9px; }
  .b-cmp-card { flex: 1; border: 1px solid var(--color-card-border); border-radius: 11px; padding: 11px; }
  .b-cmp-img { display: block; aspect-ratio: 4/3; background: #fff; border: 1px solid #f1efe7; border-radius: 6px; overflow: hidden; margin-bottom: 8px; }
  .b-cmp-img img { width: 100%; height: 100%; object-fit: contain; padding: 6px; }
  .b-cmp-title { font-size: 0.72rem; font-weight: 700; color: var(--color-text-primary); line-height: 1.2; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; }
  .b-cmp-price { font-family: 'Bricolage Grotesque', sans-serif; font-size: 0.92rem; font-weight: 800; color: var(--color-navy); margin: 2px 0 8px; }
  .b-cmp-spec { display: flex; justify-content: space-between; font-size: 0.68rem; padding: 4px 0; border-top: 1px solid #f4f2ec; }
  .b-cmp-spec span { color: var(--color-text-muted); }
  .b-cmp-spec b { color: var(--color-text-navy); font-weight: 700; }
  .vs-chip { align-self: center; flex: none; display: flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 50%; background: var(--color-navy); color: #fff; font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 0.7rem; box-shadow: 0 2px 8px rgba(22,34,76,0.3); }

  /* ── STAT ── */
  .b-stat { grid-column: 1 / -1; display: flex; align-items: center; gap: 13px; background: var(--color-navy); border-radius: var(--radius-lg); padding: 15px 18px; color: #fff; }
  .b-stat-num { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; font-size: 1.9rem; color: var(--color-amber); letter-spacing: -0.02em; }
  .b-stat-txt { font-size: 0.78rem; color: #b9c2db; line-height: 1.4; }

  .b-note { grid-column: 1 / -1; text-align: center; font-size: 0.78rem; color: var(--color-text-soft); padding: var(--space-sm) 0; }

  /* Placeholder rayado (cuando no hay catálogo en vivo) */
  .ph { display: block; width: 100%; height: 100%; background: repeating-linear-gradient(135deg, #f1efe8, #f1efe8 7px, #e8e5dc 7px, #e8e5dc 14px); }

  /* ── BUSCADOR ── */
  .b-search { grid-column: 1 / -1; display: flex; flex-direction: column; gap: 10px; }
  .search-form { display: flex; align-items: center; gap: 8px; background: var(--color-card); border: 1px solid var(--color-card-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); padding: 6px 6px 6px 14px; }
  .search-ico { flex: none; display: flex; color: var(--color-text-muted); }
  .search-input { flex: 1; min-width: 0; border: none; background: none; outline: none; font-family: inherit; font-size: 0.9rem; color: var(--color-text-primary); padding: 11px 0; }
  .search-input::placeholder { color: var(--color-text-muted); }
  .search-btn { flex: none; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border: none; border-radius: 10px; background: var(--color-amber); cursor: pointer; transition: background 0.15s; }
  .search-btn:hover { background: var(--color-amber-hover); }
  .search-chips { display: flex; flex-wrap: wrap; gap: 7px; }
  .search-chip { font-size: 0.78rem; font-weight: 600; color: var(--color-navy); background: var(--color-card); border: 1px solid var(--color-card-border); border-radius: var(--radius-pill); padding: 6px 12px; box-shadow: var(--shadow-card); transition: border-color 0.15s, color 0.15s; }
  .search-chip:hover { border-color: var(--color-blue); color: var(--color-blue); }

  /* ── GUÍAS DEL BLOG ── */
  .b-guides { grid-column: 1 / -1; }
  .b-guides-head { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; margin-bottom: 12px; }
  .b-guides-link { flex: none; font-size: 0.75rem; font-weight: 700; color: var(--color-blue); }
  /* En mobile: carrusel horizontal con snap (no genera scroll horizontal de página). */
  .guides-grid { display: grid; grid-auto-flow: column; grid-auto-columns: minmax(200px, 74%); gap: 12px; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 4px; scrollbar-width: none; }
  .guides-grid::-webkit-scrollbar { display: none; }
  .guides-grid > :global(a) { scroll-snap-align: start; }
  @media (min-width: 720px) {
    .guides-grid { grid-auto-flow: row; grid-template-columns: repeat(3, 1fr); grid-auto-columns: auto; overflow: visible; }
  }

  /* ── PREGUNTAS FRECUENTES ── */
  .b-faq { grid-column: 1 / -1; }
  .b-faq-h { margin-bottom: 12px; }
