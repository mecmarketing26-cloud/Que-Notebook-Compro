---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Quiz from '../../components/quiz/Quiz.tsx';
import { SITE } from '../../data/copy';
import '../../components/quiz/quiz.css';

export const prerender = true;
---

<BaseLayout title={`Encontrá tu notebook — ${SITE.name}`} description="Respondé unas preguntas y te recomendamos las mejores notebooks de Mercado Libre para vos, con precio y stock en vivo.">
  <div class="quiz-page">
    <header class="quiz-brandbar">
      <a href="/" class="quiz-brand" aria-label={SITE.name}>
        <span class="quiz-brand-mark">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#FFC233" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="4" rx="2"></rect><path d="M2 20h20"></path></svg>
        </span>
        <span class="quiz-brand-word">¿Qué Notebook?</span>
      </a>
      <a href="/" class="quiz-exit" aria-label="Salir">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"></path></svg>
      </a>
    </header>

    <main class="quiz-main">
      {/* El quiz es client-only: este h1 (visualmente oculto) es el único
          encabezado que ven Google y los lectores de pantalla. */}
      <h1 class="sr-only">Encontrá tu notebook ideal: test para saber qué notebook comprar</h1>
      <Quiz client:only="preact">
        <div class="quiz-panel quiz-loading" aria-busy="true"><span class="quiz-spin"></span></div>
      </Quiz>
    </main>

    <p class="quiz-legal"><a href="/terminos">Términos y privacidad</a></p>
  </div>
</BaseLayout>

<style>
  /* 100dvh (dynamic viewport) para respetar las barras del navegador mobile. */
  .quiz-page { height: 100dvh; background: var(--color-bg-deep); display: flex; flex-direction: column; overflow: hidden; }
  .quiz-brandbar {
    display: flex; align-items: center; justify-content: space-between;
    max-width: 460px; width: 100%; margin: 0 auto; padding: 16px var(--space-md) 8px;
  }
  .quiz-brand { display: flex; align-items: center; gap: 9px; }
  .quiz-brand-mark { display: flex; align-items: center; justify-content: center; width: 28px; height: 28px; border-radius: 8px; background: var(--color-navy); }
  .quiz-brand-word { font-family: 'Bricolage Grotesque Variable', sans-serif; font-weight: 800; font-size: 1.05rem; letter-spacing: -0.03em; color: var(--color-navy); }
  .quiz-exit { display: flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 10px; color: var(--color-text-soft); background: rgba(0,0,0,0.04); transition: color 0.15s, background 0.15s; }
  .quiz-exit:hover { color: var(--color-navy); background: rgba(0,0,0,0.07); }

  /* El panel llena el alto disponible en mobile (align stretch); el botón queda
     anclado abajo y las opciones scrollean si hiciera falta. */
  .quiz-main { flex: 1; min-height: 0; display: flex; align-items: stretch; justify-content: center; padding: var(--space-sm) var(--space-md) var(--space-md); }
  .quiz-legal { flex: none; text-align: center; padding: 6px 0 max(10px, env(safe-area-inset-bottom)); }
  .quiz-legal a { font-size: 0.78rem; color: var(--color-text-muted); font-weight: 500; }
  .quiz-legal a:hover { color: var(--color-navy); }

  /* En pantallas grandes vuelve a ser una "tarjeta" centrada, no full-height. */
  @media (min-width: 540px) and (min-height: 760px) {
    .quiz-main { align-items: center; padding-top: var(--space-md); }
  }
</style>
