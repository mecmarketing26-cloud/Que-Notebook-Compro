---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import { SITE, PRODUCTO } from '../data/copy';
import { getNotebook } from '../lib/catalog';
import { buildComparison } from '../shared/compare.mjs';
import type { NotebookProduct } from '../lib/types';

const ids = (Astro.url.searchParams.get('ids') ?? '')
  .split(',')
  .map((s) => s.trim())
  .filter(Boolean)
  .slice(0, 4);

const fetched = await Promise.all(ids.map((id) => getNotebook(id).catch(() => undefined)));
const products = fetched.filter((p): p is NotebookProduct => Boolean(p));

const enough = products.length >= 2;
const { rows, verdicts } = enough ? buildComparison(products) : { rows: [], verdicts: [] };

const fmtPrice = (p: NotebookProduct) =>
  p.price != null
    ? new Intl.NumberFormat('es-AR', { style: 'currency', currency: p.currency || 'ARS', maximumFractionDigits: 0 }).format(p.price)
    : PRODUCTO.sin_precio;
---

<BaseLayout title={`Comparar notebooks — ${SITE.name}`} description="Compará notebooks lado a lado y entendé cuál te conviene y por qué.">
  <Header />

  <main class="cmp-page">
    <div class="cmp-inner">
      <h1 class="cmp-title">Comparar notebooks</h1>

      {!enough ? (
        <div class="cmp-empty">
          <p class="empty-emoji">⚖️</p>
          <p>Elegí al menos 2 notebooks para comparar (tildá "Comparar" en los resultados).</p>
          <a href="/quiz/general" class="btn btn-primary">Ir al quiz</a>
        </div>
      ) : (
        <>
          {verdicts.length > 0 && (
            <section class="verdicts">
              <h2 class="cmp-h2">¿Cuál te conviene?</h2>
              <div class="verdict-grid">
                {verdicts.map((v: any) => (
                  <div class="verdict-card">
                    <span class="verdict-icon">{v.icon}</span>
                    <div>
                      <p class="verdict-title">{v.title}</p>
                      <p class="verdict-winner">🏆 {v.winner}</p>
                      <p class="verdict-why">{v.why}</p>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}

          <section class="cmp-table-wrap">
            <table class="cmp-table">
              <thead>
                <tr>
                  <th class="cmp-corner">Specs</th>
                  {products.map((p) => (
                    <th class="cmp-prod">
                      <a href={`/notebook/${p.id}`} class="cmp-prod-link">
                        {p.image && <img src={p.image} alt={p.title} width="120" height="120" loading="lazy" />}
                        <span class="cmp-prod-title">{p.title}</span>
                      </a>
                      <span class="cmp-prod-price">{fmtPrice(p)}</span>
                      <a href={p.shortUrl} target="_blank" rel="sponsored noopener noreferrer" class="btn btn-ml cmp-buy" data-item-id={p.id}>
                        {PRODUCTO.cta_comprar}
                      </a>
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {rows.map((row: any) => (
                  <tr>
                    <th class="cmp-rowlabel">{row.label}</th>
                    {row.cells.map((c: any) => (
                      <td class={c.best ? 'cmp-best' : ''}>{c.display}{c.best && <span class="cmp-tick">✓</span>}</td>
                    ))}
                  </tr>
                ))}
              </tbody>
            </table>
          </section>

          <p class="cmp-note">{PRODUCTO.precio_nota} Lo resaltado (✓) es lo mejor de cada fila.</p>
          <div class="cmp-actions"><a href="/quiz/general" class="btn btn-secondary">🔄 Volver al quiz</a></div>
        </>
      )}
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  import { trackAffiliateClick } from '../lib/analytics';
  document.querySelectorAll<HTMLElement>('[data-item-id]').forEach((el) => {
    el.addEventListener('click', () => trackAffiliateClick(el.dataset.itemId ?? '', { from: 'compare' }));
  });
</script>

<style>
  .cmp-page { padding-top: 88px; padding-bottom: var(--space-3xl); min-height: 100dvh; }
  .cmp-inner { max-width: 460px; margin: 0 auto; padding: var(--space-xl) var(--space-md); }
  .cmp-title { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; letter-spacing: -0.03em; color: var(--color-navy); font-size: clamp(2rem, 5.5vw, 3rem); text-align: center; margin-bottom: var(--space-xl); }
  .cmp-h2 { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; color: var(--color-navy); font-size: 1.5rem; margin-bottom: var(--space-md); }

  .cmp-empty { text-align: center; display: flex; flex-direction: column; align-items: center; gap: var(--space-md); padding: var(--space-2xl); color: var(--color-text-secondary); }
  .empty-emoji { font-size: 3rem; }

  /* Verdicts */
  .verdicts { margin-bottom: var(--space-2xl); }
  .verdict-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-md); }
  .verdict-card { display: flex; gap: var(--space-md); padding: var(--space-md); background: var(--color-card); border: 1px solid var(--color-card-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); }
  .verdict-icon { font-size: 1.6rem; }
  .verdict-title { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted); }
  .verdict-winner { font-weight: 700; color: var(--color-navy); margin: 2px 0; font-size: 0.95rem; }
  .verdict-why { font-size: 0.82rem; color: var(--color-text-secondary); line-height: 1.45; }

  /* Table */
  .cmp-table-wrap { overflow-x: auto; background: var(--color-card); border: 1px solid var(--color-card-border); border-radius: var(--radius-lg); box-shadow: var(--shadow-card); }
  .cmp-table { width: 100%; border-collapse: collapse; min-width: 520px; }
  .cmp-table th, .cmp-table td { border-bottom: 1px solid var(--color-card-border); padding: 12px 14px; text-align: left; font-size: 0.9rem; vertical-align: top; }
  .cmp-table tbody tr:last-child th, .cmp-table tbody tr:last-child td { border-bottom: none; }
  .cmp-corner { width: 150px; color: var(--color-navy); font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; }
  .cmp-prod { text-align: center; }
  .cmp-prod-link { display: flex; flex-direction: column; align-items: center; gap: 6px; color: var(--color-text-navy); }
  .cmp-prod-link img { border-radius: var(--radius-sm); background: #fff; object-fit: contain; padding: 6px; }
  .cmp-prod-title { font-size: 0.8rem; font-weight: 700; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .cmp-prod-price { display: block; font-family: 'Bricolage Grotesque', sans-serif; color: var(--color-navy); font-weight: 800; margin: 6px 0; }
  .cmp-buy { width: 100%; font-size: 0.8rem; padding: 9px 10px; }
  .cmp-rowlabel { color: var(--color-text-muted); font-weight: 500; }
  .cmp-best { color: var(--color-navy); font-weight: 800; background: rgba(255,194,51,0.20); }
  .cmp-tick { color: var(--color-green); margin-left: 6px; }
  .cmp-note { font-size: 0.75rem; color: var(--color-text-muted); margin-top: var(--space-md); text-align: center; }
  .cmp-actions { display: flex; justify-content: center; margin-top: var(--space-lg); }
</style>
