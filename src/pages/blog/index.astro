---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import { SITE } from '../../data/copy';
import { BLOG_TOPICS, categoryFor } from '../../data/blog';

export const prerender = true;

const [featured, ...rest] = BLOG_TOPICS;
---

<BaseLayout
  title={`Blog — guías para elegir notebook · ${SITE.name}`}
  description="Guías y rankings para elegir notebook: las mejores gamer, para estudiar, programar, MacBook, baratas y más. Actualizado con precios reales."
>
  <Header />

  <main class="blog-index">
    <div class="bi-wrap">
      <header class="bi-hero">
        <span class="bi-eyebrow">Guías para elegir</span>
        <h1 class="bi-title">Rankings y comparativas de notebooks</h1>
        <p class="bi-sub">Analizamos todas las notebooks disponibles de Mercado Libre y armamos los "mejores" por uso, marca y presupuesto. Precio actualizado.</p>
      </header>

      <!-- CTA quiz -->
      <section class="bi-quizcard">
        <div class="biq-row">
          <span class="biq-ico" aria-hidden="true">
            <svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.9 5.8a2 2 0 0 1-1.3 1.3L3 12l5.8 1.9a2 2 0 0 1 1.3 1.3L12 21l1.9-5.8a2 2 0 0 1 1.3-1.3L21 12l-5.8-1.9a2 2 0 0 1-1.3-1.3z"></path></svg>
          </span>
          <div class="biq-text">
            <div class="biq-h">¿Buscás tu notebook ideal?</div>
            <div class="biq-d">Hacé el test y te armamos un ranking a tu medida.</div>
          </div>
        </div>
        <a href="/quiz" class="btn btn-primary ctaQuiz biq-btn">
          Empezar el quiz
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16224C" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
        </a>
      </section>

      <!-- Cards -->
      <div class="bi-grid">
        <a href={`/blog/${featured.slug}`} class="bi-featured lift">
          <span class="bi-ph bi-ph-feat" aria-hidden="true"></span>
          <div class="bi-feat-body">
            <span class="bi-badge">Más leída</span>
            <div class="bi-feat-title">{featured.h1}</div>
            <div class="bi-feat-meta">
              <span class="bi-cat">{categoryFor(featured.slug)}</span>
              <span class="bi-feat-cta">Ver ranking →</span>
            </div>
          </div>
        </a>

        {rest.map((t) => (
          <a href={`/blog/${t.slug}`} class="bi-card lift">
            <span class="bi-ph bi-ph-card" aria-hidden="true"></span>
            <div class="bi-card-body">
              <span class="bi-card-cat">{categoryFor(t.slug)}</span>
              <div class="bi-card-h">{t.h1}</div>
              <span class="bi-card-cta">Ver ranking →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-index { padding-top: 64px; background: var(--color-bg-deep); min-height: 100dvh; }
  .bi-wrap { max-width: 460px; margin: 0 auto; padding: var(--space-lg) var(--space-md) var(--space-2xl); }

  .bi-hero { padding: var(--space-md) var(--space-xs) var(--space-lg); }
  .bi-eyebrow { font-size: 0.7rem; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 700; color: var(--color-text-muted); }
  .bi-title { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 800; letter-spacing: -0.025em; color: var(--color-navy); font-size: clamp(1.7rem, 6vw, 2.2rem); line-height: 1.06; margin-top: 9px; }
  .bi-sub { color: var(--color-text-soft); font-size: 0.9rem; line-height: 1.5; margin-top: 10px; }

  /* Quiz CTA card */
  .bi-quizcard { background: var(--color-navy); border-radius: var(--radius-lg); padding: 15px 16px; color: #fff; display: flex; flex-direction: column; gap: 12px; margin-bottom: var(--space-md); }
  .biq-row { display: flex; align-items: center; gap: 11px; }
  .biq-ico { flex: none; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 12px; background: rgba(255,194,51,0.16); color: var(--color-amber); }
  .biq-h { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 0.95rem; }
  .biq-d { font-size: 0.78rem; color: #b9c2db; margin-top: 2px; }
  .biq-btn { width: 100%; height: 48px; font-size: 0.95rem; }

  /* Grid */
  .bi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }

  .bi-ph { display: block; background: repeating-linear-gradient(135deg, #f1efe8, #f1efe8 7px, #e8e5dc 7px, #e8e5dc 14px); }
  .bi-ph-feat { flex: none; width: 96px; aspect-ratio: 1; border-radius: 10px; }
  .bi-ph-card { width: 100%; aspect-ratio: 16/10; }

  /* Featured (navy horizontal) */
  .bi-featured { grid-column: 1 / -1; display: flex; gap: 13px; padding: 15px; background: var(--color-navy); color: #fff; border-radius: var(--radius-md); overflow: hidden; }
  .bi-ph-feat { background: repeating-linear-gradient(135deg, #1d2a57, #1d2a57 7px, #243465 7px, #243465 14px); }
  .bi-feat-body { flex: 1; min-width: 0; display: flex; flex-direction: column; justify-content: center; }
  .bi-badge { align-self: flex-start; font-size: 0.62rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.02em; color: var(--color-navy); background: var(--color-amber); padding: 3px 9px; border-radius: 6px; }
  .bi-feat-title { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 1rem; line-height: 1.12; margin: 8px 0 6px; }
  .bi-feat-meta { display: flex; align-items: center; gap: 8px; font-size: 0.72rem; }
  .bi-cat { color: #9fb0d8; font-weight: 600; }
  .bi-feat-cta { color: var(--color-amber); font-weight: 700; margin-left: auto; }

  /* Category cards (white, image top) */
  .bi-card { display: flex; flex-direction: column; background: var(--color-card); border: 1px solid var(--color-card-border); border-radius: var(--radius-md); overflow: hidden; }
  .bi-ph-card { border-bottom: 1px solid var(--color-card-border); }
  .bi-card-body { padding: 12px 13px 14px; display: flex; flex-direction: column; flex: 1; }
  .bi-card-cat { font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; color: var(--color-blue); }
  .bi-card-h { font-family: 'Bricolage Grotesque', sans-serif; font-weight: 700; font-size: 0.9rem; line-height: 1.18; color: var(--color-navy); margin: 6px 0; flex: 1; }
  .bi-card-cta { font-size: 0.72rem; color: var(--color-text-soft); font-weight: 700; }
</style>
