---
import '../styles/global.css';
import { SITE } from '../data/copy';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: string;
  /** Páginas utilitarias/dinámicas (resultado, 404): no indexar, sí seguir links. */
  noindex?: boolean;
  /** 'article' para posts del blog; 'website' para el resto. */
  ogType?: 'website' | 'article';
}

const {
  title = SITE.name,
  description = SITE.description,
  ogImage = SITE.ogImage,
  jsonLd,
  noindex = false,
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// IDs de medición. Cada snippet se activa solo cuando el ID no es un placeholder.
// GTM administra los tags; GA4 directo (gtag) además hace que el evento
// affiliate_click de analytics.ts llegue a GA4 aunque GTM aún no esté configurado.
const GA4_ID: string = 'G-X4F7RPS2LX';
const GTM_ID: string = 'GTM-K7L9C4SF';
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content={SITE.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Las imágenes de producto vienen del CDN de Mercado Libre. -->
    <link rel="preconnect" href="https://http2.mlstatic.com" />

    {jsonLd && <script type="application/ld+json" is:inline set:html={jsonLd} />}

    <script is:inline>
      window.dataLayer = window.dataLayer || [];
    </script>

    {GTM_ID !== 'GTM-XXXXXXX' && (
      <!-- Google Tag Manager -->
      <script is:inline define:vars={{ gtmId: GTM_ID }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer',gtmId);
      </script>
    )}

    {GA4_ID !== 'G-XXXXXXXXXX' && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`} />
        <script is:inline define:vars={{ GA4_ID }}>
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA4_ID);
        </script>
      </>
    )}
  </head>
  <body>
    {GTM_ID !== 'GTM-XXXXXXX' && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}
    <slot />
  </body>
</html>
