---
import '../styles/global.css';
import { SITE } from '../data/copy';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  jsonLd?: string;
  /** Páginas utilitarias/dinámicas (resultado, 404): no indexar, sí seguir links. */
  noindex?: boolean;
  /** 'article' para posts del blog; 'website' para el resto. */
  ogType?: 'website' | 'article';
}

const {
  title = SITE.name,
  description = SITE.description,
  ogImage = SITE.ogImage,
  jsonLd,
  noindex = false,
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);

// IDs de medición. Cada snippet se activa solo cuando el ID no es un placeholder.
// GTM administra los tags; GA4 directo (gtag) además hace que el evento
// affiliate_click de analytics.ts llegue a GA4 aunque GTM aún no esté configurado.
const GA4_ID: string = 'G-X4F7RPS2LX';
const GTM_ID: string = 'GTM-K7L9C4SF';
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content={SITE.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Las imágenes de producto vienen del CDN de Mercado Libre. -->
    <link rel="preconnect" href="https://http2.mlstatic.com" />

    {jsonLd && <script type="application/ld+json" is:inline set:html={jsonLd} />}

    <!-- Analytics DIFERIDO: GTM y GA4 (~430 KiB de JS) cargan recién tras el
         load + idle, o en la primera interacción — lo que llegue antes. Los
         eventos previos quedan encolados en dataLayer (el stub de gtag) y se
         procesan al cargar, así no se pierde el affiliate_click ni el pageview. -->
    <script is:inline define:vars={{ gtmId: GTM_ID, ga4Id: GA4_ID }}>
      window.dataLayer = window.dataLayer || [];
      window.gtag = function () { dataLayer.push(arguments); };
      gtag('js', new Date());
      if (ga4Id !== 'G-XXXXXXXXXX') gtag('config', ga4Id);

      var tagsLoaded = false;
      function loadTags() {
        if (tagsLoaded) return;
        tagsLoaded = true;
        if (gtmId !== 'GTM-XXXXXXX') {
          dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
          var g = document.createElement('script');
          g.async = true;
          g.src = 'https://www.googletagmanager.com/gtm.js?id=' + gtmId;
          document.head.appendChild(g);
        }
        if (ga4Id !== 'G-XXXXXXXXXX') {
          var a = document.createElement('script');
          a.async = true;
          a.src = 'https://www.googletagmanager.com/gtag/js?id=' + ga4Id;
          document.head.appendChild(a);
        }
      }
      ['pointerdown', 'keydown', 'touchstart'].forEach(function (ev) {
        addEventListener(ev, loadTags, { once: true, passive: true });
      });
      if (document.readyState === 'complete') {
        setTimeout(loadTags, 500);
      } else {
        addEventListener('load', function () {
          'requestIdleCallback' in window
            ? requestIdleCallback(loadTags, { timeout: 2500 })
            : setTimeout(loadTags, 1200);
        });
      }
    </script>
  </head>
  <body>
    {GTM_ID !== 'GTM-XXXXXXX' && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}
    <slot />
  </body>
</html>
